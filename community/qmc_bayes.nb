Cell[CellGroupData[{

Cell["11.  Reproducibility", "Section",ExpressionUUID->"71fc866d-8bab-4e77-bef1-a7bed50e6193"],

Cell[TextData[{
 "All source code lives in the public repository ",
 StyleBox["github.com/mthiel74/QuasiMonteCarloBayesianEstimation",
  FontWeight->"SemiBold"],
 " (",
 StyleBox["https://github.com/mthiel74/QuasiMonteCarloBayesianEstimation",
  FontFamily->"Courier",
  FontSize->10],
 ")",
 ". The pipeline is pure Wolfram Language. To rebuild from scratch with \
Wolfram Language 14+:"
}], "Text",
 CellMargins->{{50, 50}, {6, 
  6}},ExpressionUUID->"296ae449-68c1-436b-83c8-5954d61236c2"],

Cell["\<\
# 1. Fetch the Theophylline data into data/
wolframscript -file wolfram/fetch_theoph.wls

# 2. Render every figure into docs/images/
wolframscript -file wolfram/run_all.wls

# 3. Rebuild this notebook
wolframscript -file community/build_notebook.wls\
\>", "Program",
 CellMargins->{{60, 30}, {6, 6}},
 ShowStringCharacters->False,
 FontFamily->"Courier",
 FontSize->11,
 Background->RGBColor[
  0.95, 0.96, 0.98],ExpressionUUID->"e15267b0-2761-4d56-9807-75f0ad2af6f8"],

Cell[TextData[{
 "The companion package ",
 StyleBox["community/qmc_bayes_helpers.wl",
  FontFamily->"Courier"],
 " is the single source of truth for the generators, the model, and the \
estimators; the figure scripts and this notebook both load it. Every code \
cell above calls into it with all arguments shown inline, so the post doubles \
as runnable documentation."
}], "Text",
 CellMargins->{{50, 50}, {6, 
  6}},ExpressionUUID->"cc336df9-cc6e-4d0a-8984-838e218de418"],

