Cell["\<\
Figure 1.  256 points in the unit square. Monte Carlo (left) clumps and \
leaves holes; Halton (centre) and Sobol\[CloseCurlyQuote] (right) lay down an \
even, gap-free pattern.\
\>", "Text",
 CellMargins->{{45, 40}, {2, 14}},
 FontSize->11.5,
 FontSlant->Italic,
 FontColor->GrayLevel[
  0.4],ExpressionUUID->"997515d7-748e-47cf-99ab-f108912c717b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2.  Low-discrepancy sequences", "Section",
 FontColor->RGBColor[
  0.153, 0.51, 0.64],ExpressionUUID->"4f886b92-db87-4e6b-a253-7928d0c56043"],

Cell[TextData[{
 "A ",
 StyleBox["low-discrepancy sequence",
  FontWeight->Bold],
 " fills the cube as evenly as possible at every scale. ",
 StyleBox["Halton",
  FontWeight->Bold],
 " uses the radical inverse of the index in a different prime base per \
coordinate; ",
 StyleBox["Sobol\[CloseCurlyQuote]",
  FontWeight->Bold],
 " is a base-2 digital net built from \"direction numbers\" (we use the Joe\
\[Dash]Kuo tables). Both are a few lines, both are in the attached package. \
Their ",
 StyleBox["L\:2082",
  FontFamily->"Times",
  FontSlant->Italic],
 " ",
 StyleBox["star discrepancy",
  FontWeight->Bold],
 " \[LongDash] the root-mean-square box-vs-volume mismatch by Warnock\
\[CloseCurlyQuote]s exact formula, a cheap proxy for the ",
 StyleBox["L\[Infinity]",
  FontFamily->"Times",
  FontSlant->Italic],
 " discrepancy in the theorem below \[LongDash] decays like ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["N", 
    RowBox[{"-", "1", "/", "2"}]], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"47d25fea-db02-46cc-9cce-62d55479381c"],
 " for random points but nearly ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["N", 
    RowBox[{"-", "1"}]], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "ac55073e-9a3b-4e21-b9f7-7db9053345c6"],
 " for these sequences:"
}], "Text",ExpressionUUID->"9d7a5675-05d8-48d3-9d33-316a9f6ff81f"],

Cell[CellGroupData[{

Cell["\<\
Nvals = 2^Range[4, 12];
dMC  = Mean[Table[StarDiscrepancyL2[
     RandomizedLDPoints[\"MonteCarlo\", #, 2, 100 r + #]], {r, 20}]] & /@ \
Nvals;
dHal = StarDiscrepancyL2[LDPoints[\"Halton\", #, 2]] & /@ Nvals;
dSob = StarDiscrepancyL2[LDPoints[\"Sobol\", #, 2]] & /@ Nvals;
ListLogLogPlot[{Transpose[{Nvals, dMC}], Transpose[{Nvals, dHal}],
   Transpose[{Nvals, dSob}]}, Joined -> True, Mesh -> All]\
\>", "Input",ExpressionUUID->"d4804b69-f600-4607-997d-85abe2533c0d"],

