Cell[TextData[{
 "Figure 8.  Posterior estimate / true value, with 90% credible intervals \
(red line = truth). The well-identified parameters (",
 Cell[BoxData[
  FormBox[
   SubscriptBox["k", "a"], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "893045c4-7891-47c3-8c6c-31476854a7c2"],
 ", ",
 StyleBox["CL",
  FontFamily->"Times",
  FontSlant->Italic],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", "1"], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "41c1cecf-0925-4ce0-a1ca-da76598df29f"],
 ") land on the truth; ",
 StyleBox["Q",
  FontFamily->"Times",
  FontSlant->Italic],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", "2"], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "11bca43b-a75a-4443-83c3-9a44a7d0d2a6"],
 " carry wide intervals that still cover it. Correct, and honest about what \
the data cannot say."
}], "Text",
 CellMargins->{{45, 40}, {2, 14}},
 FontSize->11.5,
 FontSlant->Italic,
 FontColor->GrayLevel[
  0.4],ExpressionUUID->"4ded6e3b-21e6-4aa5-9937-81f749e510dd"]
}, Open  ]],

Cell[CellGroupData[{

Cell["10.  The practical pay-off", "Section",
 FontColor->RGBColor[
  0.153, 0.51, 0.64],ExpressionUUID->"3cf2da8e-5b63-4c53-855c-ad119d933ba5"],

Cell[TextData[{
 "Slopes are abstract; model solves are money. Inverting the fitted error \
laws \[LongDash] ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", "\[Proportional]", 
    SuperscriptBox["tol", 
     RowBox[{"-", "2"}]]}], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "2799a8b4-8e66-4e1d-9d02-08d4e36fc642"],
 " for Monte Carlo, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", "\[Proportional]", 
    SuperscriptBox["tol", 
     RowBox[{"-", "1"}]]}], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "b7b67178-b646-4b93-86c1-982f47480d1f"],
 " for QMC \[LongDash] gives the number of forward-model evaluations needed \
for a target accuracy, and the ratio is the speed-up:"
}], "Text",ExpressionUUID->"a5e12d39-186d-4437-917c-2882f5121e4c"],

Cell[CellGroupData[{

Cell["\<\
fitPow[e_] := Module[{c = Fit[Transpose[{Log[Nlist], Log[e]}], {1, x}, x]},
   {Exp[c /. x -> 0], Coefficient[c, x]}];
nForTol[e_, tol_] := With[{cp = fitPow[e]}, (cp[[1]]/tol)^(1/(-cp[[2]]))];
nForTol[rmsePred[\"MonteCarlo\"], 0.001 refPred] /
   nForTol[rmsePred[\"Sobol\"], 0.001 refPred]\
\>", "Input",ExpressionUUID->"47dca5bc-170d-4687-ae9d-ccf0ba45375e"],

