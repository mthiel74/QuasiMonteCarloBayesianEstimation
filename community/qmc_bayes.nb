Cell[TextData[{
 "Figure 2.  ",
 StyleBox["L\:2082",
  FontFamily->"Times",
  FontSlant->Italic],
 " star discrepancy versus ",
 StyleBox["N",
  FontFamily->"Times",
  FontSlant->Italic],
 " (log-log). Monte Carlo rides the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["N", 
    RowBox[{"-", "1", "/", "2"}]], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"ea6c8773-8620-44ba-a0ae-510fbb0e62e4"],
 " line; Halton and Sobol\[CloseCurlyQuote] track ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["N", 
    RowBox[{"-", "1"}]], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "0acd0589-1dee-4219-bb34-c0c8dbec2ed5"],
 "."
}], "Text",
 CellMargins->{{45, 40}, {2, 14}},
 FontSize->11.5,
 FontSlant->Italic,
 FontColor->GrayLevel[
  0.4],ExpressionUUID->"b424e0c0-7223-4c18-9550-f889e5f60c52"],

Cell[TextData[{
 StyleBox["The theorem behind it.",
  FontSlant->Italic],
 " For an integrand ",
 StyleBox["f",
  FontFamily->"Times",
  FontSlant->Italic],
 " of bounded variation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "(", "f", ")"}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"a320dee9-a305-4118-a181-f0373d99c759"],
 " (Hardy\[Dash]Krause), the ",
 StyleBox["Koksma\[Dash]Hlawka inequality",
  FontWeight->Bold],
 " splits the QMC error into the function\[CloseCurlyQuote]s variation times \
the points\[CloseCurlyQuote] discrepancy:"
}], "Text",ExpressionUUID->"9ae344a4-c0eb-44f2-9b89-960bda727ab4"],

Cell[BoxData[
 FormBox[
  RowBox[{"\[LeftBracketingBar]", 
   RowBox[{
    RowBox[{
     FractionBox["1", "N"], 
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"n", "=", "1"}], "N"], 
     RowBox[{"f", "(", 
      SubscriptBox["x", "n"], ")"}]}], "-", 
    RowBox[{"\[Integral]", 
     RowBox[{"f", "(", "x", ")"}], 
     RowBox[{"\[DifferentialD]", "x"}]}]}], "\[RightBracketingBar]", "\[LessEqual]", 
   RowBox[{"V", "(", "f", ")"}], " ", 
   SubsuperscriptBox["D", "N", "*"]}], TraditionalForm]], "DisplayFormula",Exp\
ressionUUID->"53cf21d1-0fb5-4ca2-9b90-98004e145768"],

Cell[TextData[{
 "With ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["D", "N", "*"], "=", 
    RowBox[{"O", "(", 
     SuperscriptBox["N", 
      RowBox[{"-", "1"}]], 
     SuperscriptBox[
      RowBox[{"(", "log", " ", "N", ")"}], "d"], ")"}]}], TraditionalForm]], 
  "InlineFormula",ExpressionUUID->"6a7bd6d6-ff83-40b7-b7d5-6c785b586de1"],
 " \[LongDash] this ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["D", "N", "*"], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"82669991-6108-4b6f-96b2-d8996eaab610"],
 " being the ",
 StyleBox["L\[Infinity]",
  FontFamily->"Times",
  FontSlant->Italic],
 " (supremum) star discrepancy, of which Figure 2 plots the cheaper ",
 StyleBox["L\:2082",
  FontFamily->"Times",
  FontSlant->Italic],
 " proxy \[LongDash] QMC inherits that rate, ",
 StyleBox["provided",
  FontSlant->Italic],
 " the integrand is smooth enough to have finite variation. That proviso \
drives every modelling choice below."
}], "Text",ExpressionUUID->"71c7f925-8486-4ef1-bfb6-40ac9d8e75d3"]
}, Open  ]],

Cell[CellGroupData[{

Cell["3.  The model: a drug moving through the body", "Section",
 FontColor->RGBColor[
  0.153, 0.51, 0.64],ExpressionUUID->"4435c673-5fa4-48c7-8b66-8b73d8537d3b"],

Cell[TextData[{
 StyleBox["What happens when you take a pill.",
  FontSlant->Italic],
 " The drug dissolves in the gut and is absorbed into the bloodstream; the \
blood carries it to the tissues, where some of it parks reversibly; meanwhile \
the liver and kidneys clear it away. Plot the blood concentration against \
time and you get a familiar shape: a fast rise to a peak, then a slow \
decline. ",
 StyleBox["Pharmacokinetics",
  FontWeight->Bold],
 " is the quantitative description of that curve, and it is the backbone of \
every dosing decision \[LongDash] how much, how often, and how confident we \
are."
}], "Text",ExpressionUUID->"d305b2e7-4c4c-4ddc-8e49-801ed91dd863"],

Cell[TextData[{
 "We use the canonical teaching data set, ",
 StyleBox["Theophylline",
  FontWeight->Bold],
 " (an anti-asthma drug, from Boeckmann, Sheiner & Beal): 12 subjects, each a \
single oral dose, serum concentration sampled 11 times over ~25 h. \
Theophylline has a narrow therapeutic window (about 10\[Dash]20 mg/L; \
toxicity climbs above it), so getting the curve \[LongDash] and its \
uncertainty \[LongDash] right genuinely matters."
}], "Text",ExpressionUUID->"084b3239-b1d2-46aa-afe2-2305e28a7403"],

Cell[CellGroupData[{

Cell["3.1  The two-compartment system", "Subsection",
 FontColor->RGBColor[
  0.2, 0.42, 0.5],ExpressionUUID->"c7cdc822-4f19-4f52-8cc0-97dc1134bcec"],

Cell[TextData[{
 "The standard structural model splits the body into two well-mixed ",
 StyleBox["compartments",
  FontSlant->Italic],
 ": a ",
 StyleBox["central",
  FontWeight->Bold],
 " one (blood and richly-perfused organs, volume ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", "1"], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "e7f50c68-a266-49ca-8e89-2618e597c40e"],
 ") where we actually measure concentration, and a ",
 StyleBox["peripheral",
  FontWeight->Bold],
 " one (slower tissues, volume ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", "2"], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "5ec0879a-2c1f-4312-8950-abcbd5bcd227"],
 "). The swallowed dose sits in a gut depot ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["A", "g"], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "93d0177d-6196-4fbc-a8ab-c1cb1468175e"],
 " and is absorbed first-order into the central compartment; drug shuttles \
between central and peripheral, and is cleared from the central compartment. \
Writing the amounts in each compartment, the dynamics are a linear system of \
ODEs:"
}], "Text",ExpressionUUID->"1f66007d-7205-4708-96bd-6d1e5e156903"],

Cell[BoxData[
 FormBox[
  RowBox[{
   FractionBox[
    RowBox[{"\[DifferentialD]", 
     SubscriptBox["A", "g"]}], 
    RowBox[{"\[DifferentialD]", "t"}]], "=", 
   RowBox[{
    RowBox[{"-", 
     SubscriptBox["k", "a"]}], " ", 
    SubscriptBox["A", "g"]}]}], TraditionalForm]], "DisplayFormula",Expression\
UUID->"7f272ca3-eb4c-42c3-b31b-bc0553da4968"],

Cell[BoxData[
 FormBox[
  RowBox[{
   FractionBox[
    RowBox[{"\[DifferentialD]", 
     SubscriptBox["A", "1"]}], 
    RowBox[{"\[DifferentialD]", "t"}]], "=", 
   RowBox[{
    RowBox[{
     SubscriptBox["k", "a"], " ", 
     SubscriptBox["A", "g"]}], "-", 
    RowBox[{
     FractionBox["CL", 
      SubscriptBox["V", "1"]], " ", 
     SubscriptBox["A", "1"]}], "-", 
    RowBox[{
     FractionBox["Q", 
      SubscriptBox["V", "1"]], " ", 
     SubscriptBox["A", "1"]}], "+", 
    RowBox[{
     FractionBox["Q", 
      SubscriptBox["V", "2"]], " ", 
     SubscriptBox["A", "2"]}]}]}], TraditionalForm]], "DisplayFormula",Express\
ionUUID->"cc418d74-5386-4600-b7ec-a2f91085d19d"],

Cell[BoxData[
 FormBox[
  RowBox[{
   FractionBox[
    RowBox[{"\[DifferentialD]", 
     SubscriptBox["A", "2"]}], 
    RowBox[{"\[DifferentialD]", "t"}]], "=", 
   RowBox[{
    RowBox[{
     FractionBox["Q", 
      SubscriptBox["V", "1"]], " ", 
     SubscriptBox["A", "1"]}], "-", 
    RowBox[{
     FractionBox["Q", 
      SubscriptBox["V", "2"]], " ", 
     SubscriptBox["A", "2"]}]}]}], TraditionalForm]], "DisplayFormula",Express\
ionUUID->"dfce6799-10b2-4e48-81fc-bdc0123e3c93"],

Cell[TextData[{
 "with the oral dose as initial condition ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["A", "g"], "(", "0", ")", "=", "D"}], TraditionalForm]], 
  "InlineFormula",ExpressionUUID->"e719d51d-6b20-4322-b204-fabd14b280e8"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["A", "1"], "(", "0", ")", "=", 
    RowBox[{
     SubscriptBox["A", "2"], "(", "0", ")"}], "=", "0"}], TraditionalForm]], 
  "InlineFormula",ExpressionUUID->"c0617503-8114-45d6-8dc7-2584506512b6"],
 ", and the measured concentration ",
 Cell[BoxData[
  FormBox[
   RowBox[{"C", "(", "t", ")", "=", 
    RowBox[{
     SubscriptBox["A", "1"], "/", 
     SubscriptBox["V", "1"]}]}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"2449eba2-7fe1-4a60-af23-8a860613977e"],
 "."
}], "Text",ExpressionUUID->"e5565313-16ba-46c3-b797-8f77081d0006"]
}, Open  ]],

Cell[CellGroupData[{

Cell["3.2  The six parameters, one by one", "Subsection",
 FontColor->RGBColor[
  0.2, 0.42, 0.5],ExpressionUUID->"eeb39478-6f83-463c-9fc5-0a2943abf2ac"],

Cell["\<\
These are the unknowns we infer \[LongDash] each a physical quantity a \
clinician can interpret:\
\>", "Text",ExpressionUUID->"7d9a49ec-f7c3-4b31-8276-2e2ad601c504"],

Cell[TextData[{
 StyleBox["ka",
  FontFamily->"Source Code Pro",
  FontColor->RGBColor[0.153, 0.51, 0.64]],
 " \[LongDash] ",
 StyleBox["absorption rate",
  FontWeight->Bold],
 " (1/h). How fast the drug leaves the gut for the blood; it sets the \
steepness of the rising limb and the time-to-peak."
}], "Item",ExpressionUUID->"b7d89bd6-7ad3-4a14-9c95-cecc9f8d50ae"],

Cell[TextData[{
 StyleBox["CL",
  FontFamily->"Source Code Pro",
  FontColor->RGBColor[0.153, 0.51, 0.64]],
 " \[LongDash] ",
 StyleBox["clearance",
  FontWeight->Bold],
 " (L/h). Volume of blood completely cleared of drug per hour. It alone fixes \
the total exposure ",
 Cell[BoxData[
  FormBox[
   RowBox[{"AUC", "=", 
    RowBox[{"D", "/", "CL"}]}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"6fa676a2-2142-4823-b1d6-959fe2c4cad2"],
 " \[LongDash] the single most important dosing parameter."
}], "Item",ExpressionUUID->"66448cda-be69-45ea-82e1-852eed6d5fb6"],

Cell[TextData[{
 StyleBox["V1",
  FontFamily->"Source Code Pro",
  FontColor->RGBColor[0.153, 0.51, 0.64]],
 " \[LongDash] ",
 StyleBox["central volume",
  FontWeight->Bold],
 " (L). Relates dose to the initial concentration; small ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", "1"], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "c9b459fe-d406-45ba-80c1-309fc95acb1d"],
 " means a high peak."
}], "Item",ExpressionUUID->"7c06a78c-7cbc-4038-b5dd-a9f019db2de7"],

Cell[TextData[{
 StyleBox["Q",
  FontFamily->"Source Code Pro",
  FontColor->RGBColor[0.153, 0.51, 0.64]],
 " \[LongDash] ",
 StyleBox["inter-compartmental clearance",
  FontWeight->Bold],
 " (L/h). How fast drug exchanges with the tissues; it shapes the bend \
between the fast and slow phases."
}], "Item",ExpressionUUID->"c8bb4ab5-1657-4fee-8112-a3b7816fa379"],

Cell[TextData[{
 StyleBox["V2",
  FontFamily->"Source Code Pro",
  FontColor->RGBColor[0.153, 0.51, 0.64]],
 " \[LongDash] ",
 StyleBox["peripheral volume",
  FontWeight->Bold],
 " (L). How much drug the tissues hold; it stretches the slow elimination \
tail."
}], "Item",ExpressionUUID->"cf12f747-323d-4428-abac-68245095745a"],

Cell[TextData[{
 StyleBox["\[Sigma]",
  FontFamily->"Source Code Pro",
  FontColor->RGBColor[0.153, 0.51, 0.64]],
 " \[LongDash] ",
 StyleBox["residual scatter",
  FontWeight->Bold],
 " (mg/L). The combined assay-plus-model noise on each measurement \
\[LongDash] itself an unknown to be estimated."
}], "Item",ExpressionUUID->"f7277d2b-8754-47b5-bc8d-7b3268e97d00"],

Cell[TextData[{
 "From these follow the quantities dosing actually turns on: half-life ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["t", 
     RowBox[{"1", "/", "2"}]], "\[Proportional]", 
    RowBox[{
     SubscriptBox["V", "1"], "/", "CL"}]}], TraditionalForm]], 
  "InlineFormula",ExpressionUUID->"ea65ed38-3c45-4ce7-afdf-3b08cd7ac536"],
 ", exposure ",
 Cell[BoxData[
  FormBox[
   RowBox[{"D", "/", "CL"}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"14c139aa-466d-4c5d-9a91-c5c86f2a019e"],
 ", peak concentration, and the steady state reached under repeated dosing."
}], "Text",ExpressionUUID->"60749f38-b870-4614-a001-5410c4fceaa5"]
}, Open  ]],

Cell[CellGroupData[{

Cell["3.3  A closed form \[LongDash] no solver needed", "Subsection",
 FontColor->RGBColor[
  0.2, 0.42, 0.5],ExpressionUUID->"5fbb7e3c-49a3-489b-a43d-f5cfb4e06477"],

Cell[TextData[{
 "Because the system is linear, it has an exact solution: a sum of three \
exponentials in the macro-rate constants ",
 StyleBox["\[Alpha]",
  FontFamily->"Times",
  FontSlant->Italic],
 ", ",
 StyleBox["\[Beta]",
  FontFamily->"Times",
  FontSlant->Italic],
 " (the eigenvalues of the compartment matrix) and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["k", "a"], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "a7d2e695-11fc-4fe1-b8b2-5ea37b525c6c"],
 ". This makes each likelihood evaluation a handful of ",
 StyleBox["Exp",
  FontFamily->"Source Code Pro",
  FontColor->RGBColor[0.153, 0.51, 0.64]],
 "s rather than an ODE solve:"
}], "Text",ExpressionUUID->"05fd7f23-1654-46d5-8204-551e0f194707"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"C", "(", "t", ")"}], "=", 
   FractionBox[
    RowBox[{
     SubscriptBox["k", "a"], " ", "D"}], 
    SubscriptBox["V", "1"]], 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      SubscriptBox["A", "\[Alpha]"], 
      SuperscriptBox["e", 
       RowBox[{"-", "\[Alpha]", " ", "t"}]]}], "+", 
     RowBox[{
      SubscriptBox["A", "\[Beta]"], 
      SuperscriptBox["e", 
       RowBox[{"-", "\[Beta]", " ", "t"}]]}], "+", 
     RowBox[{
      SubscriptBox["A", "k"], 
      SuperscriptBox["e", 
       RowBox[{"-", 
        SubscriptBox["k", "a"], " ", "t"}]]}]}], ")"}]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"521ba063-aa23-499f-\
bc81-190cfa6f1500"],

Cell["\<\
(* The closed-form concentration; ka, CL, V1, Q, V2, dose. *)
Plot[PKConcentration[t, {1.5, 2.8, 30., 2.0, 20.}, 320.], {t, 0, 25},
   Frame -> True, FrameLabel -> {\"time (h)\", \"conc (mg/L)\"},
   PlotStyle -> RGBColor[0.153, 0.51, 0.64]]\
\>", "Input",ExpressionUUID->"35016da7-686d-4e57-a3c4-7f57c4fadb87"],

Cell[TextData[{
 StyleBox["Why bother with six parameters? ",
  FontWeight->Bold],
 "A simpler one-compartment model has three. The second compartment is what \
lets the curve bend \[LongDash] a fast distribution phase then a slow \
elimination phase \[LongDash] which real drugs do. The cost is that the two \
tissue parameters (",
 StyleBox["Q",
  FontFamily->"Source Code Pro",
  FontColor->RGBColor[0.153, 0.51, 0.64]],
 ", ",
 StyleBox["V2",
  FontFamily->"Source Code Pro",
  FontColor->RGBColor[0.153, 0.51, 0.64]],
 ") are only weakly pinned down by a single subject\[CloseCurlyQuote]s sparse \
samples. Holding honest uncertainty about them, rather than a false-precision \
point estimate, is exactly where the Bayesian treatment earns its keep."
}], "Text",
 CellFrame->{{3, 0}, {0, 0}},
 CellMargins->{{36, 40}, {8, 8}},
 CellFrameColor->RGBColor[0.153, 0.51, 0.64],
 FontSize->13,
 Background->RGBColor[0.93, 0.96, 0.97],
 FrameMargins -> 12,ExpressionUUID->"620780f1-e060-4690-bbd7-5e9d9df52932"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["4.  The Bayesian model, and why it is all integrals", "Section",
 FontColor->RGBColor[
  0.153, 0.51, 0.64],ExpressionUUID->"2490115e-9990-4486-adbd-9b08850cdd19"],

Cell[TextData[{
 "Each measurement is the model prediction plus Gaussian scatter, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["c", "i"], "=", 
    RowBox[{
     RowBox[{"C", "(", 
      SubscriptBox["t", "i"], ")"}], "+", 
     SubscriptBox["\[Epsilon]", "i"]}]}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"cec3fb40-6376-468e-8650-bccfcbda4a26"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Epsilon]", "i"], "\[Tilde]", 
    RowBox[{"N", "(", "0", ",", 
     SuperscriptBox["\[Sigma]", "2"], ")"}]}], TraditionalForm]], 
  "InlineFormula",ExpressionUUID->"739bc564-d8a4-4563-930c-1dbf49d2efb2"],
 ". All six parameters are positive, so each gets a ",
 StyleBox["lognormal",
  FontWeight->Bold],
 " prior (a normal prior on its logarithm). Bayes\[CloseCurlyQuote] rule \
gives the posterior:"
}], "Text",ExpressionUUID->"cbc660c9-3658-46bb-89b8-a5704ece877a"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"p", "(", "\[Theta]", "\[VerticalSeparator]", "c", ")"}], "\[Proportional]", 
   RowBox[{
    UnderoverscriptBox["\[Product]", 
     RowBox[{"i", "=", "1"}], "n"], 
    RowBox[{"N", "(", 
     RowBox[{
      SubscriptBox["c", "i"], "\[VerticalSeparator]", 
      RowBox[{"C", "(", 
       SubscriptBox["t", "i"], ")"}], ",", 
      SuperscriptBox["\[Sigma]", "2"]}], ")"}]}], " ", 
   RowBox[{"\[Pi]", "(", "\[Theta]", ")"}]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"26250104-5e24-4d0e-\
b9d1-7db68d106445"],

Cell[TextData[{
 "Now the key point. Everything we want from this posterior is an ",
 StyleBox["expectation",
  FontWeight->Bold],
 " \[LongDash] an integral over the six-dimensional parameter space:"
}], "Text",ExpressionUUID->"c926285f-3823-4d44-a66c-c148eb90febd"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox["E", "post"], "[", 
    RowBox[{"g", "(", "\[Theta]", ")"}], "]"}], "=", 
   RowBox[{"\[Integral]", 
    RowBox[{"g", "(", "\[Theta]", ")"}], " ", 
    RowBox[{"p", "(", "\[Theta]", "\[VerticalSeparator]", "c", ")"}], 
    RowBox[{"\[DifferentialD]", "\[Theta]"}]}]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"f7f4a265-5630-4d40-\
9337-1fb4243187a0"],

Cell[TextData[{
 "Posterior mean clearance? Take ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", "=", "CL"}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"773a6b47-db5a-4635-b09e-7bed6bbf1137"],
 ". Its uncertainty? ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", "=", 
    SuperscriptBox["CL", "2"]}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"0939c281-7623-4d48-9796-5b4059640913"],
 ". Probability the half-life exceeds a threshold? ",
 StyleBox["g",
  FontFamily->"Times",
  FontSlant->Italic],
 " an indicator. The predicted concentration at the next clinic visit? ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", "=", 
    RowBox[{"C", "(", 
     SubscriptBox["t", "*"], ")"}]}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"9727290b-4f9f-4b56-866d-331e97bac572"],
 ". Six-dimensional integrals of a smooth density, with no closed form: the \
exact setting where the choice of integration rule \[LongDash] Monte-Carlo or \
quasi-Monte-Carlo \[LongDash] decides the cost."
}], "Text",ExpressionUUID->"8bfcdfd2-9375-4f02-a0af-184780878537"]
}, Open  ]],

Cell[CellGroupData[{

Cell["5.  Classical curve-fitting versus the Bayesian posterior", "Section",
 FontColor->RGBColor[
  0.153, 0.51, 0.64],ExpressionUUID->"0c9dedbc-cb25-45a3-9e68-ba817bd536f3"],

Cell[TextData[{
 StyleBox["The classical reflex.",
  FontSlant->Italic],
 " Hand this data to a statistician and the first move is ",
 StyleBox["nonlinear least squares",
  FontWeight->Bold],
 " \[LongDash] in Wolfram Language, ",
 StyleBox["NonlinearModelFit",
  FontFamily->"Source Code Pro",
  FontColor->RGBColor[0.153, 0.51, 0.64]],
 " \[LongDash] which slides the six parameters until the squared residuals \
are smallest. It is fast and gives a tidy best-fit curve:"
}], "Text",ExpressionUUID->"0a7592fa-629f-44fb-ab26-866174b836d2"],

Cell["\<\
model = PKConcentration[t, {ka, CL, V1, Q, V2}, subj1[\"dose\"]];
nlm = NonlinearModelFit[Transpose[{subj1[\"t\"], subj1[\"c\"]}], model,
   {{ka, 1.5}, {CL, 2.8}, {V1, 30}, {Q, 2.0}, {V2, 20}}, t];
{nlm[\"BestFitParameters\"], nlm[\"ParameterErrors\"]}\
\>", "Input",ExpressionUUID->"bdb93fa0-37c1-4548-b07d-a8e7dc1e9669"],

Cell[TextData[{
 StyleBox["And the trouble it hides.",
  FontSlant->Italic],
 " The point estimate is fine, but ask for its error bars and the asymptotic \
standard errors come back enormous \[LongDash] of order ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["10", "6"], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"bd4d6ec6-f2e3-4145-b6f8-c5c428a70f2a"],
 "\[Dash]",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["10", "7"], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"5f8b7571-d1f1-45fc-9be3-e30e4966eb07"],
 " on ",
 StyleBox["CL",
  FontFamily->"Times",
  FontSlant->Italic],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", "1"], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "f827a5ff-b0e6-4739-baf1-e420d77ae00c"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", "2"], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "92f8a485-2979-4111-85f8-f8a63fab6435"],
 ", with ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", "2"], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "88972dc1-5f9b-437a-8417-3e1a64685094"],
 " driven to essentially zero. The reason is real: a two-compartment model is \
",
 StyleBox["not identifiable",
  FontWeight->Bold],
 " from one subject\[CloseCurlyQuote]s eleven points, so the least-squares \
surface is nearly flat in some directions and the linearized covariance blows \
up. Classical fitting gives you a curve but no trustworthy uncertainty."
}], "Text",ExpressionUUID->"a4279f68-e40f-4361-837b-e3d28a90bf2d"],

