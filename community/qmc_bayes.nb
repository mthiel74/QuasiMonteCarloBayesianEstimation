Cell[TextData[{
 "Figure 2.2  ",
 StyleBox["L\:2082",
  FontFamily->"Times",
  FontSlant->Italic],
 " star discrepancy of the three point sets versus ",
 StyleBox["N",
  FontFamily->"Times",
  FontSlant->Italic],
 " (log-log). Monte Carlo sits on the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["N", 
    RowBox[{"-", "1", "/", "2"}]], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"de5ba224-43e4-432d-a5b4-f732fd1e2c37"],
 " line; Halton and Sobol\[CloseCurlyQuote] track ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["N", 
    RowBox[{"-", "1"}]], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "e21674a0-9412-4930-8c75-4b256c717c20"],
 ". This is the geometric root of the whole convergence story \[LongDash] \
more uniform points integrate smooth functions more accurately."
}], "Text",
 CellMargins->{{70, 70}, {2, 14}},
 FontSize->11,
 FontSlant->Italic,
 FontColor->GrayLevel[
  0.35],ExpressionUUID->"82bcb118-eb93-42d4-80b3-704b71d101ce"],

Cell[TextData[{
 StyleBox["The theorem behind it.",
  FontSlant->Italic],
 " For a function ",
 StyleBox["f",
  FontFamily->"Times",
  FontSlant->Italic],
 " of bounded variation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "(", "f", ")"}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"bf064ad9-6b77-4059-b560-992a6bc26af8"],
 " (in the Hardy\[Dash]Krause sense), the ",
 StyleBox["Koksma\[Dash]Hlawka inequality",
  FontWeight->Bold],
 " bounds the QMC error by the product of the function's variation and the \
points' discrepancy:"
}], "Text",
 CellMargins->{{50, 50}, {6, 
  6}},ExpressionUUID->"1fe73bf3-a307-48ff-8b9c-9d624370085f"],

Cell[BoxData[
 FormBox[
  RowBox[{"\[LeftBracketingBar]", 
   RowBox[{
    RowBox[{
     FractionBox["1", "N"], 
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"n", "=", "1"}], "N"], 
     RowBox[{"f", "(", 
      SubscriptBox["x", "n"], ")"}]}], "-", 
    RowBox[{"\[Integral]", 
     RowBox[{"f", "(", "x", ")"}], 
     RowBox[{"\[DifferentialD]", "x"}]}]}], "\[RightBracketingBar]", "\[LessEqual]", 
   RowBox[{"V", "(", "f", ")"}], " ", 
   SubsuperscriptBox["D", "N", "*"]}], TraditionalForm]], "DisplayFormula",
 CellMargins->{{80, 50}, {8, 
  8}},ExpressionUUID->"7c9ea400-7000-4dbf-9a61-17836ad1c921"],

Cell[TextData[{
 "With ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["D", "N", "*"], "=", 
    RowBox[{"O", "(", 
     SuperscriptBox["N", 
      RowBox[{"-", "1"}]], 
     SuperscriptBox[
      RowBox[{"(", "log", " ", "N", ")"}], "d"], ")"}]}], TraditionalForm]], 
  "InlineFormula",ExpressionUUID->"501f4210-6d34-42ae-9a5a-99f5317e2af9"],
 " for these sequences, the QMC error inherits that rate \[LongDash] ",
 StyleBox["provided",
  FontSlant->Italic],
 " the integrand is smooth enough to have finite variation. That proviso is \
the entire art of applying QMC, and it drives every modelling choice in the \
rest of this post."
}], "Text",
 CellMargins->{{50, 50}, {6, 
  6}},ExpressionUUID->"ce76163e-2297-4316-a6f3-6f7490065147"]
}, Open  ]],

Cell[CellGroupData[{

Cell["3.  A real Bayesian problem: pharmacokinetics", "Section",ExpressionUUID->"1ed004b6-9543-4752-8a91-269e997a1b56"],

Cell[TextData[{
 StyleBox["The setting.",
  FontSlant->Italic],
 " Pharmacokinetics (PK) asks what the body does to a drug: how fast it is \
absorbed, distributed, and cleared. It is the quantitative backbone of \
dosing. A patient swallows a dose; the drug concentration in blood is \
measured at a handful of times; from those few points we must infer the \
underlying rate constants \[LongDash] and, just as importantly, our ",
 StyleBox["uncertainty",
  FontSlant->Italic],
 " about them, because dosing decisions ride on it. That is a Bayesian \
problem."
}], "Text",
 CellMargins->{{50, 50}, {6, 
  6}},ExpressionUUID->"064c7d8a-2751-4f38-8953-ab8e3bd358b5"],

Cell[TextData[{
 "We use the canonical teaching data set: ",
 StyleBox["Theophylline",
  FontWeight->Bold],
 ", an anti-asthma drug, from Boeckmann, Sheiner & Beal \[LongDash] 12 \
subjects, each given a single oral dose, with serum concentration sampled 11 \
times over about 25 hours. It ships with R\[CloseCurlyQuote]s ",
 StyleBox["datasets",
  FontFamily->"Courier"],
 " package; we pull it live and commit a tidy copy."
}], "Text",
 CellMargins->{{50, 50}, {6, 
  6}},ExpressionUUID->"603b595a-07ae-4d04-897a-3b0f8281cc99"],

Cell["\<\
(* The data are loaded in Setup as `theoph`; here is Subject 1. *)
subj1 = SelectSubject[theoph, 1];
{subj1[\"dose\"], Transpose[{subj1[\"t\"], subj1[\"c\"]}]}\
\>", "Input",
 CellMargins->{{60, 30}, {6, 6}},
 FontSize->11,ExpressionUUID->"24271b6f-7dec-41b2-b164-e4c8477f7502"],

Cell[TextData[{
 StyleBox["The forward model.",
  FontSlant->Italic],
 " A ",
 StyleBox["two-compartment model with first-order absorption",
  FontWeight->Bold],
 " is the standard structural model. The drug enters a gut depot, is absorbed \
into a central (blood) compartment at rate ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["k", "a"], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "a3faf720-9e46-4a9b-980f-2166a70d6ee3"],
 ", distributes reversibly into a peripheral (tissue) compartment, and is \
cleared from the centre. With six parameters \[LongDash] absorption rate ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["k", "a"], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "d9b7b275-1102-43ef-a92c-f4804435462c"],
 ", clearance ",
 StyleBox["CL",
  FontFamily->"Times",
  FontSlant->Italic],
 ", central volume ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", "1"], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "7e7f8df1-8f56-486f-b91c-2f90d5b673bf"],
 ", inter-compartmental clearance ",
 StyleBox["Q",
  FontFamily->"Times",
  FontSlant->Italic],
 ", peripheral volume ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", "2"], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "a641f874-5792-4460-aa3f-a61b78af9390"],
 ", and a residual scatter ",
 StyleBox["\[Sigma]",
  FontFamily->"Times",
  FontSlant->Italic],
 " \[LongDash] the concentration after a dose ",
 StyleBox["D",
  FontFamily->"Times",
  FontSlant->Italic],
 " has the closed form (a sum of three exponentials), so no ODE solver is \
needed:"
}], "Text",
 CellMargins->{{50, 50}, {6, 
  6}},ExpressionUUID->"81a2bf1b-e0de-4310-b404-e07e90af438b"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"C", "(", "t", ")"}], "=", 
   FractionBox[
    RowBox[{
     SubscriptBox["k", "a"], " ", "D"}], 
    SubscriptBox["V", "1"]], 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      SubscriptBox["A", "\[Alpha]"], 
      SuperscriptBox["e", 
       RowBox[{"-", "\[Alpha]", " ", "t"}]]}], "+", 
     RowBox[{
      SubscriptBox["A", "\[Beta]"], 
      SuperscriptBox["e", 
       RowBox[{"-", "\[Beta]", " ", "t"}]]}], "+", 
     RowBox[{
      SubscriptBox["A", "k"], 
      SuperscriptBox["e", 
       RowBox[{"-", 
        SubscriptBox["k", "a"], " ", "t"}]]}]}], ")"}]}], 
  TraditionalForm]], "DisplayFormula",
 CellMargins->{{80, 50}, {8, 
  8}},ExpressionUUID->"ae488613-f37c-46ec-85a3-cba92bb5b656"],

Cell[TextData[{
 "where ",
 StyleBox["\[Alpha]",
  FontFamily->"Times",
  FontSlant->Italic],
 " and ",
 StyleBox["\[Beta]",
  FontFamily->"Times",
  FontSlant->Italic],
 " are the macro-rate constants (eigenvalues of the linear compartment \
system) and the ",
 StyleBox["A",
  FontFamily->"Times",
  FontSlant->Italic],
 "-coefficients are fixed by them. The package evaluates this directly:"
}], "Text",
 CellMargins->{{50, 50}, {6, 
  6}},ExpressionUUID->"39183448-f003-4a55-9dc4-c635800b21cd"],

Cell["\<\
(* Concentration over 0-25 h at typical parameters, 320 mg dose. *)
Plot[PKConcentration[t, {1.5, 2.8, 30., 2.0, 20.}, 320.], {t, 0, 25},
   Frame -> True, FrameLabel -> {\"time (h)\", \"conc (mg/L)\"}]\
\>", "Input",
 CellMargins->{{60, 30}, {6, 6}},
 FontSize->11,ExpressionUUID->"691343c2-2951-4a5e-b2d2-73793736c8e8"],

Cell[TextData[{
 StyleBox["The statistical model and priors.",
  FontSlant->Italic],
 " Each measurement is the model prediction plus Gaussian scatter, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["c", "i"], "=", 
    RowBox[{
     RowBox[{"C", "(", 
      SubscriptBox["t", "i"], ")"}], "+", 
     SubscriptBox["\[Epsilon]", "i"]}]}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"2019d255-9149-4163-868f-eb4f2d551526"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Epsilon]", "i"], "\[Tilde]", 
    RowBox[{"N", "(", "0", ",", 
     SuperscriptBox["\[Sigma]", "2"], ")"}]}], TraditionalForm]], 
  "InlineFormula",ExpressionUUID->"b97fe219-eba6-4874-ad50-4267290d1a9e"],
 ". All six parameters are positive, so we put independent ",
 StyleBox["lognormal",
  FontWeight->Bold],
 " priors on them \[LongDash] equivalently, normal priors on the logs. The \
posterior is then"
}], "Text",
 CellMargins->{{50, 50}, {6, 
  6}},ExpressionUUID->"7f2ddc6a-870d-43c1-9a7d-c42379b07078"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"p", "(", "\[Theta]", "\[VerticalSeparator]", "c", ")"}], "\[Proportional]", 
   RowBox[{
    UnderoverscriptBox["\[Product]", 
     RowBox[{"i", "=", "1"}], "n"], 
    RowBox[{"N", "(", 
     RowBox[{
      SubscriptBox["c", "i"], "\[VerticalSeparator]", 
      RowBox[{"C", "(", 
       SubscriptBox["t", "i"], ")"}], ",", 
      SuperscriptBox["\[Sigma]", "2"]}], ")"}]}], " ", 
   RowBox[{"\[Pi]", "(", "\[Theta]", ")"}]}], 
  TraditionalForm]], "DisplayFormula",
 CellMargins->{{80, 50}, {8, 
  8}},ExpressionUUID->"ac01f361-fd57-48b5-acb9-36e26f278aff"],

Cell[TextData[{
 StyleBox["What we actually want are integrals.",
  FontSlant->Italic],
 " Every Bayesian deliverable is an expectation against this posterior \
\[LongDash] the mean clearance, the variance, the probability the half-life \
exceeds a threshold, the predicted concentration at the next sampling time:"
}], "Text",
 CellMargins->{{50, 50}, {6, 
  6}},ExpressionUUID->"c49946d2-199b-4adb-ada3-70e47f7f1506"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox["E", "post"], "[", 
    RowBox[{"g", "(", "\[Theta]", ")"}], "]"}], "=", 
   RowBox[{"\[Integral]", 
    RowBox[{"g", "(", "\[Theta]", ")"}], " ", 
    RowBox[{"p", "(", "\[Theta]", "\[VerticalSeparator]", "c", ")"}], 
    RowBox[{"\[DifferentialD]", "\[Theta]"}]}]}], 
  TraditionalForm]], "DisplayFormula",
 CellMargins->{{80, 50}, {8, 
  8}},ExpressionUUID->"3e491b1e-2058-48a5-b362-8599e0c642d5"],

Cell["\<\
These are six-dimensional integrals over a smooth (but not analytically \
integrable) density. That is precisely the QMC use case \[LongDash] moderate \
dimension, smooth integrand, and an evaluation cost that, in real PK/PD work \
with stiff ODE models, is the binding constraint.\
\>", "Text",
 CellMargins->{{50, 50}, {6, 
  6}},ExpressionUUID->"2437bfba-0849-4696-b09c-4ac86f5b7b63"]
}, Open  ]],

Cell[CellGroupData[{

Cell["4.  The fit: posterior of a Theophylline subject", "Section",ExpressionUUID->"f2b18272-65f6-4830-ba6a-cfc90d52865f"],

Cell[TextData[{
 StyleBox["From posterior to a tractable integral.",
  FontSlant->Italic],
 " To turn ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "post"], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"bdd613b9-62a0-404c-9da6-2a118887fe67"],
 " into something a low-discrepancy sequence can evaluate, we change \
variables so the integration domain is the unit cube. The clean, standard \
device is the ",
 StyleBox["Laplace (Gaussian) approximation",
  FontWeight->Bold],
 ": find the posterior mode in log-parameter space and the curvature \
(Hessian) there, giving a multivariate normal ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", "(", "\[Mu]", ",", "\[CapitalSigma]", ")"}], 
   TraditionalForm]], "InlineFormula",ExpressionUUID->
  "ff7fa6b4-b8af-426e-8c34-fa3b3c0bec8c"],
 " on ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CurlyPhi]", "=", 
    RowBox[{"log", " ", "\[Theta]"}]}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"2f3c834c-6864-45f4-ad96-e58b7dff0035"],
 ". A posterior expectation is then a Gaussian integral, and the ",
 StyleBox["inverse-CDF transform",
  FontWeight->Bold],
 " maps the unit cube onto it: ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CurlyPhi]", "(", "u", ")", "=", 
    RowBox[{"\[Mu]", "+", 
     RowBox[{"L", " ", 
      SuperscriptBox["\[CapitalPhi]", 
       RowBox[{"-", "1"}]], "(", "u", ")"}]}]}], TraditionalForm]], 
  "InlineFormula",ExpressionUUID->"09494c72-a676-47a6-8462-ae4485f0dda2"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"L", " ", 
    SuperscriptBox["L", "T"], "=", "\[CapitalSigma]"}], TraditionalForm]], 
  "InlineFormula",ExpressionUUID->"007c206d-7de9-4199-8211-1d9a7f2456bd"],
 " and ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalPhi]", 
    RowBox[{"-", "1"}]], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "2d8fb883-857e-44e4-8787-9c9a0e2cdcc8"],
 " the normal quantile applied coordinate-wise. No importance weights, a \
genuinely smooth integrand \[LongDash] exactly the regime where the Koksma\
\[Dash]Hlawka bound bites."
}], "Text",
 CellMargins->{{50, 50}, {6, 
  6}},ExpressionUUID->"4c1e2f1a-6cc7-4986-bcf5-b9760bdf4203"],

Cell[CellGroupData[{

Cell["\<\
(* The Laplace-Gaussian posterior (built in Setup as pkLaplace).
   Draw from it with a Sobol' point set and form the posterior-predictive
   concentration band. *)
draws  = PosteriorDraws[LDPoints[\"Sobol\", 4096, 6], pkLaplace];
tGrid  = Subdivide[0., 25., 200];
curves = ConcentrationCurves[draws, tGrid, subj1[\"dose\"]];
band   = Transpose[curves];
{Quantile[#, 0.05] & /@ band, Quantile[#, 0.95] & /@ band};   (* 90% band *)\
\>", "Input",
 CellMargins->{{60, 30}, {6, 6}},
 FontSize->11,ExpressionUUID->"6c49fb3f-7d28-4142-92eb-86a8493b47cc"],

