Cell[TextData[{
 "Figure 5.  Posterior marginals. Clearance ",
 StyleBox["CL",
  FontFamily->"Times",
  FontSlant->Italic],
 ", central volume ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", "1"], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "a7f9c9d4-6a80-4f26-8520-b8551036be0c"],
 ", and absorption ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["k", "a"], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "5df7949d-3894-4786-9233-4c7571bb3c2e"],
 " are tightly determined; ",
 StyleBox["Q",
  FontFamily->"Times",
  FontSlant->Italic],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", "2"], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "9f9cfa39-0307-49d5-9565-e1dfaf641a92"],
 " stay broad \[LongDash] honest uncertainty where the data are thin."
}], "Text",
 CellMargins->{{45, 40}, {2, 14}},
 FontSize->11.5,
 FontSlant->Italic,
 FontColor->GrayLevel[
  0.4],ExpressionUUID->"22afff37-8d13-48d3-9a8c-0c78b13b35dd"],

Cell[TextData[{
 StyleBox["Is the Gaussian approximation good enough? ",
  FontWeight->Bold],
 "We check against the full posterior via importance sampling (",
 StyleBox["FitProposal",
  FontFamily->"Source Code Pro",
  FontColor->RGBColor[0.153, 0.51, 0.64]],
 " + ",
 StyleBox["ImportanceEstimate",
  FontFamily->"Source Code Pro",
  FontColor->RGBColor[0.153, 0.51, 0.64]],
 "): in our runs the well-identified parameters agree to ~10%. And the \
convergence demonstration does not depend on the approximation being perfect \
\[LongDash] only on the integrand we actually integrate being smooth, which \
it is."
}], "Text",
 CellFrame->{{3, 0}, {0, 0}},
 CellMargins->{{36, 40}, {8, 8}},
 CellFrameColor->RGBColor[0.153, 0.51, 0.64],
 FontSize->13,
 Background->RGBColor[0.93, 0.96, 0.97],
 FrameMargins -> 12,ExpressionUUID->"045c29e0-9865-45ca-9ae7-246f7ec5ab46"]
}, Open  ]],

Cell[CellGroupData[{

Cell["7.  The convergence law", "Section",
 FontColor->RGBColor[
  0.153, 0.51, 0.64],ExpressionUUID->"3fca28bd-3803-458c-b90c-52b2c1c644c2"],

Cell[TextData[{
 "Now the measurement. Both quantities are expectations under the Laplace\
\[Dash]Gaussian posterior of \[Section]6 \[LongDash] a genuine real-data fit, \
and crucially a smooth integrand, which is what entitles QMC to its near-",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["N", 
    RowBox[{"-", "1"}]], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "d0e92391-dd64-4251-9164-5d2ea2405f4e"],
 " rate. We watch the error fall with the number of points, for Monte Carlo, \
Sobol\[CloseCurlyQuote], and Halton: the ",
 StyleBox["mean clearance",
  FontWeight->Bold],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", "post"], "[", "CL", "]"}], TraditionalForm]], 
  "InlineFormula",ExpressionUUID->"77163527-bab5-42c9-adc5-0a4c573eca54"],
 " (linear in the parameters, hence analytic under the Gaussian, so we know \
the truth exactly) and the ",
 StyleBox["predicted concentration at 6 h",
  FontWeight->Bold],
 " (a nonlinear forward-model solve at every draw, with no closed form). \
Errors are averaged over independent randomizations (a digital shift for \
Sobol\[CloseCurlyQuote], a Cranley\[Dash]Patterson rotation for Halton):"
}], "Text",ExpressionUUID->"eba1fe5d-c8fa-4126-a710-83f0934c9227"],

Cell[CellGroupData[{

Cell["\<\
Nlist = 2^Range[7, 15];   meths = {\"MonteCarlo\", \"Sobol\", \"Halton\"};
(* quantity 1: mean clearance \[LongDash] analytic under the Gaussian *)
refCL = LaplaceMeanExact[pkLaplace][[2]];
gCL   = #[[All, 2]] &;
rmseCL = Association[# ->
   ExpectationRMSE[#, Nlist, 200, pkLaplace, gCL, refCL] & /@ meths];
(* quantity 2: predicted C(6 h) \[LongDash] a nonlinear model solve *)
gPredVec = Flatten @ ConcentrationCurves[#, {6.}, subj1[\"dose\"]] &;
refPred  = Mean @ gPredVec @
   PosteriorDraws[LDPoints[\"Sobol\", 2^19, 6], pkLaplace];
rmsePred = Association[# ->
   ExpectationRMSE[#, Nlist, 200, pkLaplace, gPredVec, refPred] & /@ meths];
GraphicsRow[ListLogLogPlot[Table[Transpose[{Nlist, #[m]}], {m, meths}],
     Joined -> True, Mesh -> All] & /@ {rmseCL, rmsePred}]\
\>", "Input",ExpressionUUID->"a13c8397-6f83-4940-87d4-7c8821ea9fff"],

