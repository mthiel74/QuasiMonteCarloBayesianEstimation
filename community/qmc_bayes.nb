Cell[TextData[{
 "Figure 6.  RMSE versus ",
 StyleBox["N",
  FontFamily->"Times",
  FontSlant->Italic],
 " (log-log). ",
 StyleBox["Left:",
  FontWeight->Bold],
 " posterior mean clearance (analytic reference). ",
 StyleBox["Right:",
  FontWeight->Bold],
 " posterior-predictive concentration at 6 h. Monte Carlo follows ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["N", 
    RowBox[{"-", "1", "/", "2"}]], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"a8461d30-e66d-4b7e-a9bf-f17dc1b05a73"],
 " (slope \[TildeTilde] ",
 StyleBox["-0.50",
  FontFamily->"Times",
  FontSlant->Italic],
 "); Sobol\[CloseCurlyQuote] and Halton both track ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["N", 
    RowBox[{"-", "1"}]], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "455483fe-4aea-45b6-a4f8-b4db2ce2850c"],
 " (measured slopes from about ",
 StyleBox["-0.8",
  FontFamily->"Times",
  FontSlant->Italic],
 " to ",
 StyleBox["-0.96",
  FontFamily->"Times",
  FontSlant->Italic],
 ", Sobol\[CloseCurlyQuote] steepest). At ",
 StyleBox["N = 32768",
  FontFamily->"Times",
  FontSlant->Italic],
 " Sobol\[CloseCurlyQuote] is ~50\[Times] more accurate, and the gap keeps \
widening."
}], "Text",
 CellMargins->{{45, 40}, {2, 14}},
 FontSize->11.5,
 FontSlant->Italic,
 FontColor->GrayLevel[
  0.4],ExpressionUUID->"45dcecb4-69e4-41f6-b0a0-7d73f4c59f60"],

Cell[TextData[{
 "That is the headline, on a real-data posterior: at a fixed budget of model \
solves Sobol\[CloseCurlyQuote] reaches roughly ",
 StyleBox["50\[Times]",
  FontFamily->"Times",
  FontSlant->Italic],
 " lower error than Monte Carlo at ",
 StyleBox["N = 32768",
  FontFamily->"Times",
  FontSlant->Italic],
 " \[LongDash] about 1.7 extra correct digits \[LongDash] and the gap keeps \
widening. The result rides on the integrand being smooth (\[Section]6), not \
on the Gaussian being exact."
}], "Text",ExpressionUUID->"47e0f875-977a-49d4-9419-daa33edcae9f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["8.  Why dimension matters", "Section",
 FontColor->RGBColor[
  0.153, 0.51, 0.64],ExpressionUUID->"c464095c-92b1-4086-805f-51e9e41c5e4c"],

Cell[TextData[{
 "The ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"(", "log", " ", "N", ")"}], "d"], TraditionalForm]], 
  "InlineFormula",ExpressionUUID->"2fc671ec-2a18-4ace-a39e-640482cbe874"],
 " factor is not cosmetic: filling a cube evenly gets exponentially harder as \
the dimension grows, so the QMC advantage erodes. Fix the budget ",
 StyleBox["N",
  FontFamily->"Times",
  FontSlant->Italic],
 " and measure how many times more accurate Sobol\[CloseCurlyQuote] is than \
MC on a smooth test integral, across dimension:"
}], "Text",ExpressionUUID->"eea979af-5a82-491a-a0d9-d35e3f6731bc"],

Cell[CellGroupData[{

Cell["\<\
cAmp  = 0.6;
fMean = Function[pts, Mean[Times @@@ (1 + cAmp Cos[2 Pi pts])]];   (* exact 1 \
*)
rmseAt[meth_, d_, n_] := Sqrt@Mean@Table[
   (fMean[RandomizedLDPoints[meth, n, d, 53 r + d]] - 1.)^2, {r, 120}];
gain[n_] := Table[rmseAt[\"MonteCarlo\", d, n]/rmseAt[\"Sobol\", d, n], {d, \
2, 12}];
{gain[4096], gain[65536]}\
\>", "Input",ExpressionUUID->"72c743a2-9c12-4815-9ba1-71a99ca036eb"],

