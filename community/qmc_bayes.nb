Cell["\<\
Figure 2.1  256 points in the unit square. Monte Carlo (left) clumps and \
leaves holes; Halton (centre) and Sobol\[CloseCurlyQuote] (right) lay down an \
even, gap-free pattern. The empty patches in the random panel are exactly the \
wasted samples behind the square-root wall.\
\>", "Text",
 CellMargins->{{70, 70}, {2, 14}},
 FontSize->11,
 FontSlant->Italic,
 FontColor->GrayLevel[
  0.35],ExpressionUUID->"b28b81be-df7e-4964-b5e3-3eb1ed0b10c8"],

Cell[TextData[{
 "The uniformity gap is quantitative. The ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["L", "2"], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "89c09bfd-5e29-466f-bf5b-b7ceb9db6a94"],
 " ",
 StyleBox["star discrepancy",
  FontWeight->Bold],
 " (computed exactly by Warnock\[CloseCurlyQuote]s formula) decays like ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["N", 
    RowBox[{"-", "1", "/", "2"}]], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"da288fde-0d6a-4671-b58d-2c87bf5f373a"],
 " for random points but nearly ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["N", 
    RowBox[{"-", "1"}]], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "57bd4cab-1684-4282-8656-2e035f440312"],
 " for the low-discrepancy sets:"
}], "Text",
 CellMargins->{{50, 50}, {6, 
  6}},ExpressionUUID->"23632570-a22f-4bd8-9177-aa24dbdba411"],

Cell[CellGroupData[{

Cell["\<\
(* L2 star discrepancy vs N. *)
Nvals = 2^Range[4, 12];
dMC  = Mean[Table[StarDiscrepancyL2[
     RandomizedLDPoints[\"MonteCarlo\", #, 2, 100 r + #]], {r, 20}]] & /@ \
Nvals;
dHal = StarDiscrepancyL2[LDPoints[\"Halton\", #, 2]] & /@ Nvals;
dSob = StarDiscrepancyL2[LDPoints[\"Sobol\", #, 2]] & /@ Nvals;
ListLogLogPlot[{Transpose[{Nvals, dMC}], Transpose[{Nvals, dHal}],
   Transpose[{Nvals, dSob}]}, Joined -> True, Mesh -> All]\
\>", "Input",
 CellMargins->{{60, 30}, {6, 6}},
 FontSize->11,ExpressionUUID->"254f4993-d94f-4e2e-a3e9-93245307ad0f"],

