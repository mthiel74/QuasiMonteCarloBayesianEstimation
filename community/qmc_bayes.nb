Cell[TextData[{
 "Figure 7.  Sobol\[CloseCurlyQuote] efficiency gain (MC RMSE / Sobol\
\[CloseCurlyQuote] RMSE, fixed budget) versus dimension. Tens to hundreds of \
times more accurate in low dimension, decaying toward parity as the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"(", "log", " ", "N", ")"}], "d"], TraditionalForm]], 
  "InlineFormula",ExpressionUUID->"16eb1e7d-9a8f-419d-a4e2-236fcd51fd9c"],
 " penalty bites. The six-parameter PK problem sits where the gain is still \
large."
}], "Text",
 CellMargins->{{45, 40}, {2, 14}},
 FontSize->11.5,
 FontSlant->Italic,
 FontColor->GrayLevel[
  0.4],ExpressionUUID->"4d3bbbe2-4e9f-42de-913e-1a3646bcd5de"]
}, Open  ]],

Cell[CellGroupData[{

Cell["9.  Does it recover the truth?", "Section",
 FontColor->RGBColor[
  0.153, 0.51, 0.64],ExpressionUUID->"dbf8d6f9-1302-45e7-8937-81193ce04138"],

Cell["\<\
A fast wrong answer is worthless, so we generate data from known parameters, \
fit, and check the posterior brackets them (on a deliberately denser time \
grid than the real 11-point design, to isolate parameter recovery from data \
sparsity):\
\>", "Text",ExpressionUUID->"4499d8cf-b873-4dbf-af7f-60c0ecebd794"],

Cell[CellGroupData[{

Cell["\<\
thetaTrue = {1.20, 2.50, 30.0, 1.80, 22.0, 0.45};
{synProblem, synConc} = SyntheticProblem[thetaTrue, 320.0,
   {0.25, 0.5, 1, 1.5, 2, 3, 4, 6, 8, 10, 12, 16, 20, 24, 30},
   priorMedians, priorLogSD, 4242];
synDraws = PosteriorDraws[LDPoints[\"Sobol\", 8192, 6],
   LaplacePosterior[synProblem]];
Mean /@ Transpose[synDraws]\
\>", "Input",ExpressionUUID->"7e5f9a14-c11e-4d5e-a892-d5624994dd1b"],

