Cell[TextData[{
 "Figure 4.2  Posterior marginals for the six parameters. Clearance ",
 StyleBox["CL",
  FontFamily->"Times",
  FontSlant->Italic],
 ", central volume ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", "1"], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "09f18a54-0db1-4f6c-b036-d6b701ce74f5"],
 ", and absorption ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["k", "a"], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "a506f1ac-a4d2-49ae-9a81-3a9f7541fac0"],
 " are tightly determined; the inter-compartmental terms ",
 StyleBox["Q",
  FontFamily->"Times",
  FontSlant->Italic],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", "2"], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "063eb83e-d330-439b-bc70-689f0015b982"],
 " are much broader \[LongDash] a single subject\[CloseCurlyQuote]s data only \
weakly identify the peripheral compartment. That mix of well- and \
weakly-constrained parameters is typical of real inference."
}], "Text",
 CellMargins->{{70, 70}, {2, 14}},
 FontSize->11,
 FontSlant->Italic,
 FontColor->GrayLevel[
  0.35],ExpressionUUID->"11e5939b-dc29-458e-96ac-5f2847006ded"],

Cell[TextData[{
 StyleBox["Honest check: is the Gaussian posterior good enough? ",
  FontWeight->Bold],
 "The Laplace approximation is exact only for Gaussian posteriors. We verify \
it against the ",
 StyleBox["full",
  FontSlant->Italic],
 " posterior computed by self-normalized importance sampling (the package\
\[CloseCurlyQuote]s ",
 StyleBox["FitProposal",
  FontFamily->"Courier"],
 " + ",
 StyleBox["ImportanceEstimate",
  FontFamily->"Courier"],
 "). The well-identified parameters (",
 StyleBox["CL",
  FontFamily->"Times",
  FontSlant->Italic],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", "1"], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "5788425c-eae0-456b-88af-b40f0cec2530"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["k", "a"], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "c48515d3-9d05-4758-8b20-fa65d2a89d30"],
 ") agree to within about 10%; the weakly-identified ",
 StyleBox["Q",
  FontFamily->"Times",
  FontSlant->Italic],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", "2"], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "272523e3-520a-484b-b5d4-6d884270b2ae"],
 " differ more, because their true posterior is skewed. The convergence \
demonstration below does not depend on the approximation being perfect \
\[LongDash] it only needs the integrand we actually integrate to be smooth, \
which it is."
}], "Text",
 CellFrame->{{4, 0}, {0, 0}},
 CellMargins->{{70, 70}, {6, 4}},
 CellFrameColor->RGBColor[0.45, 0.55, 0.7],
 FontSize->11,
 FontColor->GrayLevel[0.25],
 Background->RGBColor[
  0.93, 0.95, 0.99],ExpressionUUID->"53b4abb1-512e-4dce-98fd-8566c10ad909"],

Cell["\<\
(* Cross-check: full posterior mean via importance sampling. *)
estIS = ImportanceEstimate[LDPoints[\"Sobol\", 2^16, 6],
   FitProposal[pkProblem], pkProblem];
{LaplaceMeanExact[pkLaplace], estIS[\"postMean\"], estIS[\"essFraction\"]}\
\>", "Input",
 CellMargins->{{60, 30}, {6, 6}},
 FontSize->11,ExpressionUUID->"ba459a0e-d56e-4b2b-afeb-c245a425ce89"]
}, Open  ]],

Cell[CellGroupData[{

Cell["5.  The convergence law (the headline)", "Section",ExpressionUUID->"f3fea31f-ed0f-4388-8590-128692f00683"],

Cell["\<\
Now the measurement. We estimate two posterior expectations of the real fit \
and watch the error fall as the number of points grows, for Monte Carlo, \
Sobol\[CloseCurlyQuote], and Halton:\
\>", "Text",
 CellMargins->{{50, 50}, {6, 
  6}},ExpressionUUID->"5dcb1929-6932-4184-8a1b-68c13164596e"],

Cell[TextData[{
 "\[Bullet] ",
 StyleBox["the posterior mean clearance",
  FontWeight->Bold],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", "post"], "[", "CL", "]"}], TraditionalForm]], 
  "InlineFormula",ExpressionUUID->"edc0739d-3e3b-453b-a5c5-5b3447e37381"],
 ". Under the Gaussian posterior this has a closed form, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"exp", "(", 
    RowBox[{
     SubscriptBox["\[Mu]", "CL"], "+", 
     RowBox[{
      SubscriptBox["\[CapitalSigma]", "CL"], "/", "2"}]}], ")"}], 
   TraditionalForm]], "InlineFormula",ExpressionUUID->
  "413a48cd-8288-4e4c-b27d-287910c5eafe"],
 ", so we know the exact answer and can measure true error."
}], "Text",
 CellMargins->{{50, 50}, {6, 
  6}},ExpressionUUID->"8c3229f1-57a5-4fea-a265-cf2e25f863b8"],

Cell[TextData[{
 "\[Bullet] ",
 StyleBox["the posterior-predictive concentration at 6 h",
  FontWeight->Bold],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", "post"], "[", 
    RowBox[{"C", "(", "6", ")"}], "]"}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"f28c5a6a-4d0b-4cef-bd4e-b4d15a944d44"],
 ", which has no closed form \[LongDash] each integrand evaluation is a \
forward model solve, so this is the realistic, expensive case. Its reference \
value comes from a high-",
 StyleBox["N",
  FontFamily->"Times",
  FontSlant->Italic],
 " Sobol\[CloseCurlyQuote] run."
}], "Text",
 CellMargins->{{50, 50}, {6, 
  6}},ExpressionUUID->"01fe5d31-c6d4-41be-bb6a-d35366bdb752"],

Cell[TextData[{
 "For each method and each ",
 StyleBox["N",
  FontFamily->"Times",
  FontSlant->Italic],
 " we average over independent randomizations (a digital shift for Sobol\
\[CloseCurlyQuote], a Cranley\[Dash]Patterson rotation for Halton, reseeding \
for MC) and report the root-mean-square error:"
}], "Text",
 CellMargins->{{50, 50}, {6, 
  6}},ExpressionUUID->"b8c68795-1095-458d-8a70-65140da3e695"],

Cell[CellGroupData[{

Cell["\<\
(* RMSE vs N for E[CL], analytic reference. *)
Nlist = 2^Range[7, 15];
refCL = LaplaceMeanExact[pkLaplace][[2]];
gCL   = #[[All, 2]] &;                       (* CL is parameter 2 *)
rmseCL = Association[# -> ExpectationRMSE[#, Nlist, 200, pkLaplace, gCL, \
refCL] & /@
   {\"MonteCarlo\", \"Sobol\", \"Halton\"}];
ListLogLogPlot[Table[Transpose[{Nlist, rmseCL[m]}],
   {m, {\"MonteCarlo\", \"Sobol\", \"Halton\"}}], Joined -> True, Mesh -> All]\
\>", "Input",
 CellMargins->{{60, 30}, {6, 6}},
 FontSize->11,ExpressionUUID->"eae43b01-ae97-4b11-8a0a-639dbb7206b3"],

